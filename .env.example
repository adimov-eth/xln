# XLN Deployment Configuration
# Copy this file to .env and fill in your values

# Deployer private key (without 0x prefix)
DEPLOYER_PRIVATE_KEY=

# RPC URLs (optional - defaults to public endpoints)
MAINNET_RPC_URL=https://eth.llamarpc.com
SEPOLIA_RPC_URL=https://rpc.sepolia.org
GOERLI_RPC_URL=https://rpc.ankr.com/eth_goerli
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Production RPC URLs (for future use)
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org

# Block explorer API keys for contract verification
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISM_API_KEY=
BASESCAN_API_KEY=

# Gas reporting
REPORT_GAS=false
COINMARKETCAP_API_KEY=

# Deployment options
VERIFY_CONTRACTS=true
DEPLOY_MOCKS=false

# Validator configuration
VALIDATOR_1_KEY=
VALIDATOR_2_KEY=
VALIDATOR_3_KEY=

# Initial entity configuration
FOUNDATION_ADDRESS=
TREASURY_ADDRESS=
RISK_COMMITTEE_ADDRESS=

# Fee parameters (in wei)
BASE_FEE=1000
MAX_FEE_MULTIPLIER=10

# Network-specific gas prices (optional - uses auto if not set)
SEPOLIA_GAS_PRICE=20000000000
MUMBAI_GAS_PRICE=35000000000

# Monitoring endpoints (for production)
GRAFANA_URL=
PROMETHEUS_URL=
ALERTMANAGER_URL=

# API Gateway configuration
API_HOST=localhost
API_PORT=3000
API_CORS_ORIGINS=http://localhost:3000,https://app.xln.network
API_RATE_LIMIT=100

# P2P Network
BOOTSTRAP_NODE_1=
BOOTSTRAP_NODE_2=
BOOTSTRAP_NODE_3=

# Debug options
DEBUG=false
VERBOSE_LOGGING=false