{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xln.dev/schemas/input.schema.json",
  "title": "XLN Reference Input",
  "oneOf": [
    { "type": "object", "properties": {"type": {"const": "noop"}}, "required": ["type"] },
    { "type": "object",
      "properties": {"type": {"const": "governance-enabled"}, "entity-id": {}, "control-supply": {}, "dividend-supply": {}, "articles": {"type": "object"}},
      "required": ["type", "entity-id"] },
    { "type": "object",
      "properties": {"type": {"const": "control-shares-received"}, "entity-id": {}, "control-amount": {}, "dividend-amount": {}},
      "required": ["type", "entity-id"] },
    { "type": "object",
      "properties": {"type": {"const": "reserve-to-reserve"}, "entity-id": {}, "from-asset": {"type": "string"}, "to-asset": {"type": "string"}, "amount": {"type": ["integer", "string"]}},
      "required": ["type", "entity-id", "from-asset", "to-asset", "amount"] },
    { "type": "object",
      "properties": {"type": {"const": "transfer-reserve-to-collateral"}, "entity-id": {}, "asset": {"type": "string"}, "amount": {"type": ["integer", "string"]}},
      "required": ["type", "entity-id", "asset", "amount"] },
    { "type": "object",
      "properties": {"type": {"const": "dispute-start"}, "channel-id": {"type": "string"}, "reason": {"type": "string"}},
      "required": ["type", "channel-id"] },
    { "type": "object",
      "properties": {"type": {"const": "cooperative-close"}, "channel-id": {"type": "string"}},
      "required": ["type", "channel-id"] }
    ,
    { "type": "object",
      "properties": {"type": {"const": "invoice-issued"},
                      "invoice-id": {"type": ["string", "integer"]},
                      "supplier": {}, "buyer": {},
                      "amount": {"type": ["integer", "string"]},
                      "currency": {"type": "string"},
                      "due-date": {"type": ["string", "integer"]},
                      "terms": {"type": ["string", "object"]},
                      "refs": {"type": "array", "items": {"type": "string"}}},
      "required": ["type", "invoice-id", "supplier", "buyer", "amount", "currency", "due-date"] },
    { "type": "object",
      "properties": {"type": {"const": "invoice-accepted"},
                      "invoice-id": {"type": ["string", "integer"]},
                      "acceptor": {}},
      "required": ["type", "invoice-id", "acceptor"] }
  ]
}
