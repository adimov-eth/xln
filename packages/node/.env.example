# Server configuration
PORT=3000
NODE_ENV=development

# Database paths
DB_PATH=./data

# Logging
LOG_LEVEL=info

# Channel configuration
DISPUTE_PERIOD=86400        # 24 hours in seconds
DISPUTE_CHECK_INTERVAL=300  # 5 minutes in seconds
MAX_BLOCK_SIZE=1000        # Maximum number of transactions per block

# Dispute configuration
DISPUTE_EVIDENCE_MAX_SIZE=1048576  # 1MB in bytes
DISPUTE_MAX_CHALLENGES=3           # Maximum number of challenges per dispute
DISPUTE_RESOLUTION_TIMEOUT=3600    # 1 hour in seconds